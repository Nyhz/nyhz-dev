---
import '../styles/tokens.css';
import '../styles/global.css';
const { title = 'nyhz' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <slot name="bg" />
    <slot name="frame" />
    <main class="page"><slot /></main>
    <slot name="overlay" />
  </body>
</html>
