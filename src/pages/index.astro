---
import Base from '../layouts/Base.astro';
import Field from '../components/Field.astro';
import Frame from '../components/Frame.astro';
import Hero from '../components/Hero.astro';
import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Loader from '../components/Loader.astro';
import { getContent } from '../scripts/content';
const { profile, projects, skills } = await getContent();
---
<Base title={`${profile.name} — ${profile.role}`}>
  <Field slot="bg" />
  <Frame slot="frame" />
  <ThemeToggle slot="corner" />
  <Loader name={profile.name} tagline={profile.role} slot="overlay" />

  <section class="hero">
    <Hero
      name={profile.name}
      role={profile.role}
      location={profile.location}
      socials={profile.socials}
    />
  </section>
  <section class="lower">
    <Projects projects={projects} />
    <Skills skills={skills} />
  </section>
</Base>
