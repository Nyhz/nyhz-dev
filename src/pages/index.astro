---
import Base from '../layouts/Base.astro';
import Identity from '../components/Identity.astro';
import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
import Socials from '../components/Socials.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Scene from '../components/Scene.astro';
import Loader from '../components/Loader.astro';
import { getContent } from '../scripts/content';
const { profile, projects, skills } = await getContent();
---
<Base title={`${profile.name} — ${profile.role}`}>
  <Loader name={profile.name} tagline={profile.role} slot="overlay" />
  <ThemeToggle slot="corner" />
  <Identity slot="tl" name={profile.name} role={profile.role} location={profile.location} />
  <Scene slot="tr" />
  <Socials slot="mid" socials={profile.socials} />
  <Projects slot="bl" projects={projects} />
  <Skills slot="br" skills={skills} />
</Base>
