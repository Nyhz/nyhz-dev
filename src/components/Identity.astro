---
const { name, role, location } = Astro.props;
---
<div class="identity" data-anim>
  <h1>hi, i'm {name}</h1>
  <p class="role">{role}</p>
  <p class="loc">{location}</p>
</div>
<style>
  .identity h1 { font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 600; letter-spacing: -0.02em; }
  .role { margin-top: 0.5rem; }
  .loc { color: var(--muted); }
</style>
