---
const { projects } = Astro.props;
const HIGHLIGHT = 3;
const MAX = 10;
const shown = projects.slice(0, MAX);
const total = String(shown.length).padStart(2, '0');
const canExpand = shown.length > HIGHLIGHT;
---
<div class="projects" data-anim>
  <p class="sec-label">— selected work <span class="sec-count">[{total}]</span></p>
  <ul>
    {shown.map((p, i) => (
      <li class:list={['prj', i >= HIGHLIGHT && 'prj--extra']} data-proj={p.slug}
        data-title={p.title} data-desc={p.description} data-cover={p.coverUrl} data-repo={p.repoUrl}
        data-live={p.deployUrl} data-download={p.downloadUrl} data-tags={p.tags.join(' · ')}>
        <div class="prj__trigger" tabindex="0" role="button" aria-label={`Preview ${p.title}`}>
          <span class="prj__bar"></span>
          <span class="prj__inner">
            <span class="prj__head">
              <span class="prj__idx">{String(i + 1).padStart(2, '0')}</span>
              <span class="prj__name">{p.title}</span>
            </span>
            {p.description && <span class="prj__desc">{p.description}</span>}
          </span>
        </div>
      </li>
    ))}
  </ul>
  {canExpand && (
    <button class="prj-more" data-projects-toggle type="button">
      <span data-more-label>show all</span>
      <span class="prj-more__ar" aria-hidden="true">↓</span>
    </button>
  )}
</div>

<style>
  .projects ul { list-style: none; border-bottom: 1px solid var(--line); }
  /* no hover while the list is animating (rows sliding under the cursor) */
  .projects.is-busy ul { pointer-events: none; }
  .prj__trigger { position: relative; display: block; padding: 1rem 0; cursor: pointer;
    border-top: 1px solid var(--line); outline: none; }
  .prj__trigger:focus-visible { outline: 1px solid var(--muted); outline-offset: 4px; }

  /* shift via transform only → never reflows, no layout shift on hover */
  .prj__inner { display: block; transition: transform 0.35s cubic-bezier(.2,.7,.2,1); }
  .prj__trigger:hover .prj__inner, .prj__trigger:focus-visible .prj__inner { transform: translateX(1.1rem); }

  .prj__bar { position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--fg);
    transform: scaleY(0); transform-origin: top; transition: transform 0.35s cubic-bezier(.2,.7,.2,1); }
  .prj__trigger:hover .prj__bar, .prj__trigger:focus-visible .prj__bar { transform: scaleY(1); }

  .prj__head { display: flex; align-items: baseline; gap: 0.9rem; }
  .prj__idx { font: 0.78rem var(--mono); color: var(--muted); transition: color 0.25s; }
  .prj__trigger:hover .prj__idx { color: var(--fg); }
  .prj__name { flex: 1; font-size: clamp(1.2rem, 2.1vw, 1.5rem); font-weight: 500; letter-spacing: -0.01em; }

  .prj__desc { display: block; margin-top: 0.3rem; padding-left: calc(0.78rem + 0.9rem);
    font-size: 0.82rem; color: var(--dim);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .prj-more { display: inline-flex; align-items: center; gap: 0.45rem; margin-top: 1.2rem;
    background: none; border: none; cursor: pointer; padding: 0;
    font: 500 0.7rem var(--mono); letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted);
    transition: color 0.25s; }
  .prj-more:hover { color: var(--fg); }
  .prj-more__ar { transition: transform 0.3s ease; }
  .page.projects-open .prj-more__ar { transform: rotate(180deg); }

  /* touch devices keep a sticky :hover after a tap — kill the row hover effects
     there so a focused row's arrow doesn't bleed onto the preview */
  @media (hover: none) {
    .prj__trigger:hover .prj__inner, .prj__trigger:focus-visible .prj__inner,
    .prj__trigger:active .prj__inner { transform: none; }
    .prj__trigger:hover .prj__bar, .prj__trigger:focus-visible .prj__bar { transform: scaleY(0); }
    .prj__trigger:hover .prj__idx { color: var(--muted); }
  }
  @media (prefers-reduced-motion: reduce) {
    .prj__inner, .prj__bar, .prj__idx, .prj-more, .prj-more__ar { transition: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const page = document.querySelector('.page');
  const btn = document.querySelector('[data-projects-toggle]');
  const label = document.querySelector('[data-more-label]');
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const DUR = 0.6;
  let animating = false;

  // Collapse the header (height + opacity + its gap margin) and grow the list to
  // fill. Multiple growers (spacers + lower) keep the fill smooth; the header
  // fully disappears and the list rises into its place.
  let storedMb = '';
  function animateLayout(open: boolean, instant: boolean) {
    const hero = document.querySelector('.hero') as HTMLElement | null;
    const lower = document.querySelector('.lower');
    const mobile = matchMedia('(max-width: 720px)').matches;
    if (open && hero) storedMb = getComputedStyle(hero).marginBottom;
    const growers: [Element | null, number][] = mobile
      ? [[hero, open ? 0 : 1], [lower, open ? 1 : 0]]
      : [[document.querySelector('[data-spacer-top]'), open ? 0 : 1],
         [document.querySelector('[data-spacer-bottom]'), open ? 0 : 1],
         [lower, open ? 1 : 0]];

    if (instant) {
      if (hero) gsap.set(hero, { height: open ? 0 : 'auto', opacity: open ? 0 : 1, marginBottom: open ? 0 : (storedMb || 0) });
      growers.forEach(([el, v]) => el && gsap.set(el, { flexGrow: v }));
      return;
    }
    if (hero) {
      if (open) {
        // start from the exact measured height so there's no auto→px snap
        const h = hero.getBoundingClientRect().height;
        gsap.fromTo(hero, { height: h }, { height: 0, opacity: 0, marginBottom: 0, duration: DUR, ease: 'power2.inOut' });
      } else {
        gsap.to(hero, { height: 'auto', opacity: 1, marginBottom: storedMb || 0, duration: DUR, ease: 'power2.inOut' });
      }
    }
    growers.forEach(([el, v]) => el && gsap.to(el, { flexGrow: v, duration: DUR, ease: 'power2.inOut' }));
  }

  function setExpanded(open: boolean) {
    if (!page || animating || page.classList.contains('projects-open') === open) return;
    animating = true;
    const projects = document.querySelector('.projects');
    projects?.classList.add('is-busy');
    document.querySelector('.lower__track')?.classList.remove('is-preview');

    const apply = () => {
      page.classList.toggle('projects-open', open);
      if (label) label.textContent = open ? 'show less' : 'show all';
    };

    if (reduce) {
      if (!open) page.classList.remove('projects-reveal');
      apply();
      if (open) page.classList.add('projects-reveal');
      animateLayout(open, true);
      projects?.classList.remove('is-busy');
      animating = false;
      return;
    }

    const finish = () => { projects?.classList.remove('is-busy'); animating = false; };

    // the button stays hidden through the whole transition and only fades back in
    // (opacity only, no movement) once everything has settled in its final place
    const revealButton = () => gsap.to(btn, { opacity: 1, duration: 0.3, ease: 'power2.out', onComplete: finish });

    if (open) {
      gsap.to(btn, { opacity: 0, duration: 0.15, ease: 'power2.in', onComplete: () => {
        apply();
        animateLayout(true, false);
        gsap.delayedCall(DUR, () => {
          page.classList.add('projects-reveal');
          gsap.fromTo('.prj--extra', { opacity: 0, y: 14 },
            { opacity: 1, y: 0, duration: 0.45, stagger: 0.05, ease: 'power2.out', onComplete: revealButton });
        });
      } });
    } else {
      gsap.to(btn, { opacity: 0, duration: 0.15, ease: 'power2.in', onComplete: () => {
        gsap.to('.prj--extra', {
          opacity: 0, y: 14, duration: 0.32, ease: 'power2.in', stagger: { each: 0.05, from: 'end' },
          onComplete: () => {
            page.classList.remove('projects-reveal');
            apply();
            animateLayout(false, false);
            gsap.delayedCall(DUR, revealButton);
          },
        });
      } });
    }
  }

  btn?.addEventListener('click', () => setExpanded(!page?.classList.contains('projects-open')));

  // when expanded, a click outside the 900px column collapses (like show less)
  document.addEventListener('click', (e) => {
    if (!page?.classList.contains('projects-open')) return;
    if (!page.contains(e.target as Node)) setExpanded(false);
  });
</script>
