---
const { projects } = Astro.props;
const shown = projects.slice(0, 4);
const count = String(shown.length).padStart(2, '0');
---
<div class="projects" data-anim>
  <p class="sec-label">— selected work <span class="sec-count">[{count}]</span></p>
  <ul>
    {shown.map((p, i) => (
      <li class="prj">
        <a href={p.repoUrl} target="_blank" rel="noopener noreferrer">
          <span class="prj__bar"></span>
          <span class="prj__head">
            <span class="prj__idx">{String(i + 1).padStart(2, '0')}</span>
            <span class="prj__name">{p.title}</span>
            <span class="prj__ar">↗</span>
          </span>
          {(p.description || p.tags.length > 0) && (
            <span class="prj__sub">
              {p.description && <span class="prj__desc">{p.description}</span>}
              {p.tags.length > 0 && <span class="prj__tags">{p.tags.join(' · ')}</span>}
            </span>
          )}
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
  .projects ul { list-style: none; }
  .prj a { position: relative; display: block; padding: 1.05rem 0 1.05rem 0;
    border-top: 1px solid var(--line); transition: padding-left 0.35s cubic-bezier(.2,.7,.2,1); }
  .prj:last-child a { border-bottom: 1px solid var(--line); }
  .prj a:hover { padding-left: 1.1rem; }

  /* magic: a marker line that grows from the left on hover */
  .prj__bar { position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--fg);
    transform: scaleY(0); transform-origin: top; transition: transform 0.35s cubic-bezier(.2,.7,.2,1); }
  .prj a:hover .prj__bar { transform: scaleY(1); }

  .prj__head { display: flex; align-items: baseline; gap: 0.9rem; }
  .prj__idx { font: 0.78rem var(--mono); color: var(--muted); transition: color 0.25s; }
  .prj a:hover .prj__idx { color: var(--fg); }
  .prj__name { flex: 1; font-size: clamp(1.25rem, 2.2vw, 1.6rem); font-weight: 500; letter-spacing: -0.01em; }
  .prj__ar { font-size: 1.1rem; color: var(--muted); opacity: 0; transform: translate(-6px, 6px);
    transition: all 0.3s ease; }
  .prj a:hover .prj__ar { opacity: 1; transform: translate(0, 0); color: var(--fg); }

  .prj__sub { display: flex; justify-content: space-between; align-items: baseline; gap: 1.2rem;
    margin-top: 0.5rem; padding-left: calc(0.78rem + 0.9rem); }
  .prj__desc { font-size: 0.9rem; color: var(--dim); line-height: 1.5; }
  .prj__tags { font: 0.74rem var(--mono); color: var(--muted); white-space: nowrap; letter-spacing: 0.02em; }

  @media (prefers-reduced-motion: reduce) {
    .prj a, .prj__ar, .prj__bar, .prj__idx { transition: none; }
  }
</style>
