---
const { projects } = Astro.props;
const shown = projects.slice(0, 4);
---
<div class="projects" data-anim>
  <p class="sec-label">— selected work</p>
  <ul>
    {shown.map((p, i) => (
      <li class="prj">
        <a href={p.repoUrl} target="_blank" rel="noopener noreferrer">
          <span class="prj__head">
            <span class="prj__idx">{String(i + 1).padStart(2, '0')}</span>
            <span class="prj__name">{p.title}</span>
            <span class="prj__ar">↗</span>
          </span>
          {(p.description || p.tags.length > 0) && (
            <span class="prj__sub">
              {p.description && <span class="prj__desc">{p.description}</span>}
              {p.tags.length > 0 && <span class="prj__tags">{p.tags.join(' · ')}</span>}
            </span>
          )}
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
  .projects ul { list-style: none; }
  .prj a { display: block; padding: 0.85rem 0 0.85rem 0; border-top: 1px solid var(--line);
    transition: padding-left 0.3s cubic-bezier(.2,.7,.2,1); }
  .prj:last-child a { border-bottom: 1px solid var(--line); }
  .prj a:hover { padding-left: 0.7rem; }

  .prj__head { display: flex; align-items: baseline; gap: 0.75rem; }
  .prj__idx { font: 0.7rem var(--mono); color: var(--muted); }
  .prj__name { flex: 1; font-size: 1.05rem; font-weight: 500; position: relative; }
  .prj__name::after { content: ""; position: absolute; left: 0; bottom: -2px; width: 100%; height: 1px;
    background: var(--fg); transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease; }
  .prj a:hover .prj__name::after { transform: scaleX(1); }
  .prj__ar { color: var(--muted); opacity: 0; transform: translate(-4px, 4px); transition: all 0.25s ease; }
  .prj a:hover .prj__ar { opacity: 1; transform: translate(0, 0); color: var(--fg); }

  .prj__sub { display: flex; justify-content: space-between; gap: 1rem; margin-top: 0.35rem;
    padding-left: calc(0.7rem + 0.75rem); }
  .prj__desc { font-size: 0.82rem; color: var(--dim); }
  .prj__tags { font: 0.72rem var(--mono); color: var(--muted); white-space: nowrap; letter-spacing: 0.02em; }

  @media (prefers-reduced-motion: reduce) {
    .prj a, .prj__ar, .prj__name::after { transition: none; }
  }
</style>
