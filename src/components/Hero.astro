---
const { name, role, location, socials = [] } = Astro.props;
---
<div class="hero-block" data-anim>
  <p class="eyebrow">{role}{location ? ` — ${location}` : ''}</p>
  <h1 class="hero-name" aria-label={name}>
    {[...name].map((ch) => <span class="hc">{ch === ' ' ? ' ' : ch}</span>)}
  </h1>
  {socials.length > 0 && (
    <nav class="hero-socials">
      {socials.map((s: { label: string; url: string }, i: number) => (
        <a href={s.url} target="_blank" rel="noopener noreferrer">
          <span class="sx">{String(i + 1).padStart(2, '0')}</span>
          <span class="sl">{s.label}</span>
          <span class="ar">↗</span>
        </a>
      ))}
    </nav>
  )}
</div>

<style>
  .hero-block { display: flex; flex-direction: column; gap: 1.5rem; }
  .hero-name {
    font-size: clamp(3rem, 9vw, 6.5rem); font-weight: 600; letter-spacing: -0.045em;
    line-height: 0.88; display: flex; flex-wrap: wrap;
  }
  .hc { display: inline-block; transition: transform 0.3s cubic-bezier(.2,.7,.2,1); }
  .hero-name:hover .hc { transform: translateY(-0.06em); }
  .hero-name:hover .hc:nth-child(2n) { transform: translateY(0.06em); }

  .hero-socials { display: flex; gap: 2rem; margin-top: 0.6rem; }
  .hero-socials a { position: relative; display: inline-flex; align-items: baseline; gap: 0.45rem;
    font: 500 0.8rem var(--mono); letter-spacing: 0.02em; color: var(--muted); padding-bottom: 4px;
    transition: color 0.25s; }
  .hero-socials .sx { font-size: 0.7em; color: var(--muted); }
  .hero-socials .ar { font-size: 0.85em; transition: transform 0.25s; }
  .hero-socials a::after { content: ""; position: absolute; left: 0; bottom: 0; width: 100%; height: 1px;
    background: currentColor; transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease; }
  .hero-socials a:hover { color: var(--fg); }
  .hero-socials a:hover .ar { transform: translate(3px, -3px); }
  .hero-socials a:hover::after { transform: scaleX(1); }

  @media (prefers-reduced-motion: reduce) {
    .hc, .hero-socials a, .hero-socials .ar, .hero-socials a::after { transition: none; }
    .hero-name:hover .hc, .hero-name:hover .hc:nth-child(2n) { transform: none; }
  }
</style>
