---
const { name, role, location, socials = [] } = Astro.props;

const ICONS: Record<string, string> = {
  github: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.8c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.7 18 5 18 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>',
  linkedin: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.8 0 0 .78 0 1.74v20.51C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.75V1.74C24 .78 23.2 0 22.22 0z"/></svg>',
  default: '<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="4"/></svg>',
};
const icon = (label: string) => ICONS[label.toLowerCase()] ?? ICONS.default;
---
<div class="hero-block" data-anim>
  <p class="eyebrow">{role}{location ? ` — ${location}` : ''}</p>
  <h1 class="hero-name" data-text={name}>{name}</h1>
  {socials.length > 0 && (
    <nav class="hero-socials">
      {socials.map((s: { label: string; url: string }) => (
        <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.label}>
          <span class="ico" set:html={icon(s.label)} />
          <span class="sl">{s.label}</span>
          <span class="ar">↗</span>
        </a>
      ))}
    </nav>
  )}
</div>

<style>
  .hero-block { display: flex; flex-direction: column; gap: 1.6rem; }
  .hero-name {
    position: relative; font-size: clamp(3.2rem, 9.5vw, 7rem); font-weight: 600;
    letter-spacing: -0.045em; line-height: 0.95; width: max-content; max-width: 100%;
    padding-bottom: 0.06em;
  }
  /* Chromatic glitch (same vibe as the loader) on duplicated colour layers,
     so the real name is never clipped. */
  .hero-name::before, .hero-name::after {
    content: attr(data-text); position: absolute; left: 0; top: 0; width: 100%;
    padding-bottom: 0.06em; pointer-events: none; opacity: 0;
  }
  .hero-name::before { color: #ff2e63; }
  .hero-name::after { color: #2ee6ff; }
  .hero-name.glitching { animation: hgMain 0.42s steps(2) 1; }
  .hero-name.glitching::before { animation: hgR 0.42s steps(2) 1; }
  .hero-name.glitching::after { animation: hgC 0.42s steps(2) 1; }
  @keyframes hgMain {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(2px); }
    50% { transform: translateX(-2px); }
    75% { transform: translateX(1px); }
  }
  @keyframes hgR {
    0%, 100% { opacity: 0; transform: translate(0,0); clip-path: inset(0 0 0 0); }
    20% { opacity: 0.9; transform: translate(-4px,0); clip-path: inset(0 0 62% 0); }
    40% { opacity: 0.9; transform: translate(4px,0); clip-path: inset(58% 0 0 0); }
    60% { opacity: 0.9; transform: translate(-3px,0); clip-path: inset(24% 0 44% 0); }
    80% { opacity: 0.7; transform: translate(2px,0); clip-path: inset(0 0 72% 0); }
  }
  @keyframes hgC {
    0%, 100% { opacity: 0; transform: translate(0,0); clip-path: inset(0 0 0 0); }
    20% { opacity: 0.9; transform: translate(4px,0); clip-path: inset(0 0 58% 0); }
    40% { opacity: 0.9; transform: translate(-4px,0); clip-path: inset(54% 0 0 0); }
    60% { opacity: 0.9; transform: translate(3px,0); clip-path: inset(40% 0 24% 0); }
    80% { opacity: 0.7; transform: translate(-2px,0); clip-path: inset(0 0 68% 0); }
  }

  .hero-socials { display: flex; gap: 1.8rem; margin-top: 0.6rem; flex-wrap: wrap; }
  .hero-socials a { position: relative; display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.9rem; font-weight: 500; color: var(--muted); padding-bottom: 5px; transition: color 0.25s; }
  .hero-socials .ico { width: 17px; height: 17px; display: inline-flex; }
  .hero-socials .ico svg { width: 100%; height: 100%; }
  .hero-socials .ar { font-size: 0.78em; opacity: 0.5; transition: transform 0.25s, opacity 0.25s; }
  .hero-socials a::after { content: ""; position: absolute; left: 0; bottom: 0; height: 1px; width: 100%;
    background: currentColor; transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease; }
  .hero-socials a:hover { color: var(--fg); }
  .hero-socials a:hover .ar { transform: translate(2px, -2px); opacity: 1; }
  .hero-socials a:hover::after { transform: scaleX(1); }

  @media (prefers-reduced-motion: reduce) {
    .hero-socials a, .hero-socials .ar, .hero-socials a::after { transition: none; }
    .hero-name.glitching,
    .hero-name.glitching::before,
    .hero-name.glitching::after { animation: none; }
  }
</style>

<script>
  const el = document.querySelector('.hero-name');
  if (el && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const loop = () => {
      el.classList.add('glitching');
      setTimeout(() => el.classList.remove('glitching'), 420);
      setTimeout(loop, 3000 + Math.random() * 3000);
    };
    setTimeout(loop, 3000 + Math.random() * 3000);
  }
</script>
