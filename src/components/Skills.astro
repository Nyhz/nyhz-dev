---
const { skills } = Astro.props;
const shown = skills.slice(0, 5);
---
<div class="skills" data-anim>
  <p class="sec-label sec-label--r">— skills</p>
  <ul>
    {shown.map((g) => (
      <li class="skl">
        <span class="skl__name">{g.title}</span>
        <span class="skl__items">{g.items.join(' · ')}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .sec-label--r { text-align: right; }
  .skills ul { list-style: none; }
  .skl { display: flex; flex-direction: column; align-items: flex-end; text-align: right;
    gap: 0.3rem; padding: 0.85rem 0; border-top: 1px solid var(--line); }
  .skl:last-child { border-bottom: 1px solid var(--line); }
  .skl__name { font-size: 1.05rem; font-weight: 500; }
  .skl__items { font: 0.72rem var(--mono); color: var(--muted); letter-spacing: 0.02em; }

  @media (max-width: 720px) {
    .sec-label--r { text-align: left; }
    .skl { align-items: flex-start; text-align: left; }
  }
</style>
