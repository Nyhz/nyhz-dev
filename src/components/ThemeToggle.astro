<button class="theme-toggle" title="Toggle theme" aria-label="Toggle theme" data-theme-toggle>
  <svg class="sun-and-moon" aria-hidden="true" width="26" height="26" viewBox="0 0 24 24">
    <mask class="moon" id="moon-mask">
      <rect x="0" y="0" width="100%" height="100%" fill="white" />
      <circle cx="24" cy="10" r="6" fill="black" />
    </mask>
    <circle class="sun" cx="12" cy="12" r="6" mask="url(#moon-mask)" fill="currentColor" />
    <g class="sun-beams" stroke="currentColor">
      <line x1="12" y1="1" x2="12" y2="3" />
      <line x1="12" y1="21" x2="12" y2="23" />
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
      <line x1="1" y1="12" x2="3" y2="12" />
      <line x1="21" y1="12" x2="23" y2="12" />
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
    </g>
  </svg>
</button>
<style>
  .theme-toggle {
    position: fixed; z-index: 6;
    top: clamp(24px, 2.8vw, 42px); right: clamp(24px, 2.8vw, 42px);
    inline-size: 48px; block-size: 48px; padding: 0; cursor: pointer; color: var(--muted);
    background: color-mix(in srgb, var(--bg) 70%, transparent);
    border: 1px solid var(--line); border-radius: 50%; display: grid; place-items: center;
    backdrop-filter: blur(4px);
    transition: color 0.25s, border-color 0.3s, transform 0.4s cubic-bezier(.2,.7,.2,1);
    -webkit-tap-highlight-color: transparent;
  }
  .theme-toggle:hover { color: var(--fg); border-color: var(--fg); transform: scale(1.07); }
  .theme-toggle:active { transform: scale(0.92); }

  /* Sun & moon icon — after Adam Argyle's web.dev theme-switch component */
  .sun-and-moon { inline-size: 26px; block-size: 26px; }
  .sun-and-moon > :is(.moon, .sun, .sun-beams) { transform-origin: center; }
  .sun-and-moon > :is(.moon, .sun) { fill: currentColor; }
  .sun-and-moon > .sun-beams { stroke: currentColor; stroke-width: 2px; }

  :root[data-theme='dark'] .sun-and-moon > .sun { transform: scale(1.75); }
  :root[data-theme='dark'] .sun-and-moon > .sun-beams { opacity: 0; }
  :root[data-theme='dark'] .sun-and-moon > .moon > circle { transform: translateX(-7px); }
  @supports (cx: 1) {
    :root[data-theme='dark'] .sun-and-moon > .moon > circle { cx: 17; transform: translateX(0); }
  }

  @media (prefers-reduced-motion: no-preference) {
    .sun-and-moon > .sun { transition: transform 0.5s cubic-bezier(.5,1.25,.75,1.25); }
    .sun-and-moon > .sun-beams { transition: transform 0.5s cubic-bezier(.5,1.5,.75,1.25), opacity 0.5s cubic-bezier(.25,0,.3,1); }
    .sun-and-moon .moon > circle { transition: transform 0.25s cubic-bezier(0,0,0,1); }
    @supports (cx: 1) { .sun-and-moon .moon > circle { transition: cx 0.25s cubic-bezier(0,0,0,1); } }
    :root[data-theme='dark'] .sun-and-moon > .sun { transition-timing-function: cubic-bezier(.25,0,.3,1); transition-duration: 0.25s; transform: scale(1.75); }
    :root[data-theme='dark'] .sun-and-moon > .sun-beams { transition-duration: 0.15s; transform: rotateZ(-25deg); }
    :root[data-theme='dark'] .sun-and-moon > .moon > circle { transition-duration: 0.5s; transition-delay: 0.25s; }
  }
</style>
<script>
  import { applyTheme, nextTheme, readStoredTheme, resolveInitialTheme } from '../scripts/theme';
  const btn = document.querySelector('[data-theme-toggle]') as HTMLElement | null;
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const current = () => (document.documentElement.dataset.theme === 'light' ? 'light' : 'dark');

  const resolved = resolveInitialTheme(readStoredTheme(), current() === 'dark');
  if (resolved !== current()) applyTheme(resolved);

  const swap = () => applyTheme(nextTheme(current()));
  btn?.addEventListener('click', (e) => {
    const start = (document as any).startViewTransition?.bind(document);
    if (reduce || !start) { swap(); return; }
    // circular reveal of the new theme, expanding from the button
    const x = e.clientX, y = e.clientY;
    const end = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y));
    start(swap).ready.then(() => {
      document.documentElement.animate(
        { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${end}px at ${x}px ${y}px)`] },
        { duration: 600, easing: 'cubic-bezier(.4,0,.2,1)', pseudoElement: '::view-transition-new(root)' },
      );
    });
  });
</script>
