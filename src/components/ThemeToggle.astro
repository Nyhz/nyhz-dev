<button class="theme-toggle" aria-label="Toggle theme" data-theme-toggle>
  <span class="tt-ring" aria-hidden="true"></span>
  <canvas class="tt-orb" aria-hidden="true"></canvas>
</button>
<style>
  .theme-toggle {
    position: fixed; z-index: 6;
    top: clamp(24px, 2.8vw, 42px); right: clamp(24px, 2.8vw, 42px);
    width: 52px; height: 52px; padding: 0; cursor: pointer; color: var(--fg);
    background: color-mix(in srgb, var(--bg) 70%, transparent);
    border: 1px solid var(--line); border-radius: 50%; display: grid; place-items: center;
    backdrop-filter: blur(4px);
    transition: border-color 0.3s, transform 0.4s cubic-bezier(.2,.7,.2,1);
  }
  .theme-toggle:hover { border-color: var(--fg); transform: scale(1.07); }
  .theme-toggle:active { transform: scale(0.92); }
  .tt-orb { width: 42px; height: 42px; display: block; }

  .tt-ring { position: absolute; inset: -1px; border-radius: 50%; border: 1px solid var(--fg);
    opacity: 0; pointer-events: none; }
  .theme-toggle.pulsing .tt-ring { animation: ttPulse 0.65s ease-out; }
  @keyframes ttPulse { from { opacity: 0.6; transform: scale(1); } to { opacity: 0; transform: scale(1.7); } }

  @media (prefers-reduced-motion: reduce) { .theme-toggle, .tt-ring { transition: none; animation: none; } }
</style>
<script>
  import { gsap } from 'gsap';
  import { createOrb } from '../scripts/orb';
  import { applyTheme, nextTheme, readStoredTheme, resolveInitialTheme, THEME_EVENT } from '../scripts/theme';

  const btn = document.querySelector('[data-theme-toggle]') as HTMLElement | null;
  const canvas = document.querySelector('.tt-orb') as HTMLCanvasElement | null;
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const current = () => (document.documentElement.dataset.theme === 'light' ? 'light' : 'dark');
  const fg = () => getComputedStyle(document.documentElement).getPropertyValue('--fg').trim() || '#f1efe9';

  const resolved = resolveInitialTheme(readStoredTheme(), current() === 'dark');
  if (resolved !== current()) applyTheme(resolved);

  let orb: ReturnType<typeof createOrb> | null = null;
  const webglOk = (() => { try { return !!document.createElement('canvas').getContext('webgl'); } catch { return false; } })();
  if (canvas && webglOk) {
    orb = createOrb(canvas);
    orb.setColor(fg());
    orb.uniforms.uMix.value = current() === 'light' ? 1 : 0;
    orb.start();
  }

  // the orb morphs (moon ↔ sun) + spins when the theme changes
  window.addEventListener(THEME_EVENT, () => {
    if (!orb) return;
    orb.setColor(fg());
    const target = current() === 'light' ? 1 : 0;
    if (reduce) { orb.uniforms.uMix.value = target; return; }
    gsap.to(orb.uniforms.uMix, { value: target, duration: 0.7, ease: 'power2.inOut' });
    gsap.to(orb.uniforms.uRot, { value: orb.uniforms.uRot.value + Math.PI, duration: 0.9, ease: 'power2.inOut' });
  });

  const swap = () => applyTheme(nextTheme(current()));
  btn?.addEventListener('click', (e) => {
    btn.classList.remove('pulsing'); void btn.offsetWidth; btn.classList.add('pulsing');
    const start = (document as any).startViewTransition?.bind(document);
    if (reduce || !start) { swap(); return; }
    const x = e.clientX, y = e.clientY;
    const end = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y));
    start(swap).ready.then(() => {
      document.documentElement.animate(
        { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${end}px at ${x}px ${y}px)`] },
        { duration: 600, easing: 'cubic-bezier(.4,0,.2,1)', pseudoElement: '::view-transition-new(root)' },
      );
    });
  });
</script>
