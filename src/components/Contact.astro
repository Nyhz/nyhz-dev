---
// The "available for work" chip and the contact form are ONE element: on open
// the chip's bordered pill is lifted out of flow (portaled to <body>, so the
// hero's overflow:hidden can't clip it) and its border grows — width first,
// then height — into a card that reveals the form. Closing reverses it.
---
<div class="contact-backdrop" data-contact-backdrop hidden></div>
<div class="contact" data-contact role="dialog" aria-modal="true" aria-label="contact form">
  <div class="contact-head">
    <button class="contact-trigger" type="button" data-contact-open aria-haspopup="dialog" aria-expanded="false">
      <i class="live" aria-hidden="true"></i>
      <span class="lbl">available for work</span>
      <span class="cue" aria-hidden="true">+</span>
    </button>
    <button class="contact-close" type="button" data-contact-close aria-label="close">✕</button>
  </div>
  <div class="contact-panel" data-contact-panel>
    <form class="contact-form" data-contact-form novalidate>
      <label data-field><span>name</span><input name="name" type="text" maxlength="100" autocomplete="off" required /></label>
      <label data-field><span>email</span><input name="email" type="email" maxlength="200" autocomplete="off" required /></label>
      <label data-field><span>message</span><textarea name="message" maxlength="5000" rows="4" autocomplete="off" required></textarea></label>
      <input class="hp" name="company" type="text" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <div class="contact-form__foot" data-field>
        <span class="contact-status" data-contact-status role="status" aria-live="polite"></span>
        <button class="contact-send" type="submit">send</button>
      </div>
    </form>
  </div>
</div>

<style>
  /* ---- collapsed: the pill chip (border lives here, it's what expands) ---- */
  .contact {
    display: inline-flex; flex-direction: column; align-items: stretch;
    border: 1px solid var(--line); border-radius: 12px; background: transparent;
    color: var(--muted); transition: color 0.2s, border-color 0.2s;
  }
  .contact-head { display: flex; align-items: center; }
  .contact-trigger {
    display: inline-flex; align-items: center; gap: 7px; padding: 7px 12px;
    background: transparent; border: 0; color: inherit; cursor: pointer; white-space: nowrap;
    font: 500 0.62rem var(--mono); letter-spacing: 0.16em; text-transform: uppercase;
  }
  .contact:not(.contact--open):hover { color: var(--fg); border-color: var(--fg); }
  .contact-trigger:focus-visible { outline: 1px solid var(--fg); outline-offset: 3px; border-radius: 12px; }
  .live { width: 6px; height: 6px; border-radius: 50%; background: #3ad29f; box-shadow: 0 0 8px #3ad29f;
    animation: live 1.6s ease-in-out infinite; flex: none; }
  .cue { font-size: 0.95em; opacity: 0.6; transition: transform 0.2s, opacity 0.2s; }
  .contact:not(.contact--open):hover .cue { opacity: 1; transform: rotate(90deg); }
  @keyframes live { 0%, 100% { opacity: 1; } 50% { opacity: 0.25; } }

  .contact-close { display: none; background: transparent; border: 0; color: var(--muted);
    cursor: pointer; font-size: 0.8rem; line-height: 1; padding: 6px; margin-right: 6px; }
  .contact-close:hover { color: var(--fg); }
  .contact-panel { display: none; }

  /* ---- backdrop ---- */
  .contact-backdrop { position: fixed; inset: 0; z-index: 8; background: rgba(11,11,11,0.72);
    backdrop-filter: blur(4px); opacity: 0; }

  /* ---- open: same element, now a card. Geometry (position/size) is owned by
         GSAP inline styles; this rule only changes appearance. Border-radius
         stays 12px throughout, so the box never looks like a capsule. ---- */
  .contact--open { z-index: 9; overflow: hidden; background: var(--bg);
    border-color: var(--fg); color: var(--fg); }
  .contact--open .contact-head { justify-content: space-between; }
  .contact--open .contact-trigger { flex: 1; cursor: default; color: var(--muted); }
  .contact--open .cue { display: none; }
  .contact--open .contact-close { display: block; }
  .contact--open .contact-panel { display: block; flex: 1; min-height: 0; overflow-y: hidden;
    padding: 0.5rem 12px 14px; }

  .contact-form { display: flex; flex-direction: column; gap: 0.85rem; }
  .contact-form label { display: flex; flex-direction: column; gap: 0.35rem;
    font: 500 0.6rem var(--mono); letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
  .contact-form input, .contact-form textarea {
    background: transparent; border: 1px solid var(--line); border-radius: 6px; padding: 0.55rem 0.65rem;
    color: var(--fg); font: 400 0.9rem var(--font); resize: none; }
  .contact-form input:focus, .contact-form textarea:focus { outline: none; border-color: var(--fg); }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .contact-form__foot { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: 0.2rem; }
  .contact-status { font: 400 0.72rem var(--mono); color: var(--muted); }
  .contact-status[data-state="error"] { color: #ff6b6b; }
  .contact-status[data-state="ok"] { color: #3ad29f; }
  .contact-send { background: var(--fg); color: var(--bg); border: 0; border-radius: 6px;
    padding: 0.5rem 1.1rem; cursor: pointer; font: 500 0.66rem var(--mono); letter-spacing: 0.16em;
    text-transform: uppercase; transition: opacity 0.2s; }
  .contact-send:disabled { opacity: 0.5; cursor: default; }

  @media (prefers-reduced-motion: reduce) {
    .live { animation: none; }
    .contact, .cue { transition: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const contact = document.querySelector<HTMLElement>('[data-contact]');
  const trigger = document.querySelector<HTMLButtonElement>('[data-contact-open]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-contact-close]');
  const backdrop = document.querySelector<HTMLElement>('[data-contact-backdrop]');
  const panel = document.querySelector<HTMLElement>('[data-contact-panel]');
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = () => matchMedia('(max-width: 720px)').matches;

  if (contact && trigger && closeBtn && backdrop && panel) {
    const fields = Array.from(panel.querySelectorAll<HTMLElement>('[data-field]'));
    const home = contact.parentElement!; // .hero-headline — restored here on close
    let open = false;
    let firstRect: DOMRect | null = null;

    // Lift the (already portaled) chip out of flow, anchored to its original
    // top-right corner, and measure the card size it should grow into.
    const liftAndMeasure = () => {
      const right = Math.round(window.innerWidth - firstRect!.right);
      gsap.set(contact, {
        position: 'fixed', top: Math.round(firstRect!.top), right, left: 'auto',
        width: firstRect!.width, height: firstRect!.height, margin: 0,
      });
      contact.classList.add('contact--open');
      const targetW = Math.min(window.innerWidth * 0.92, 400);
      gsap.set(contact, { width: targetW, height: 'auto' });
      const naturalH = contact.offsetHeight;
      const targetH = Math.min(naturalH, window.innerHeight - firstRect!.top - 16);
      return { targetW, targetH, scroll: targetH < naturalH - 1 };
    };

    // Mobile: open as a full-width sheet (viewport minus margins), natural height
    // (centered, scrolls if it would exceed the screen), revealed top→down. The
    // chip-anchored desktop morph doesn't fit a narrow screen.
    const M = 16;
    const openMobile = () => {
      contact.classList.add('contact--open');
      gsap.set(contact, { position: 'fixed', left: M, right: 'auto', top: 0,
        width: window.innerWidth - M * 2, height: 'auto', margin: 0 });
      const naturalH = contact.offsetHeight;
      const maxH = window.innerHeight - M * 2;
      const targetH = Math.min(naturalH, maxH);
      const top = Math.max(M, Math.round((window.innerHeight - targetH) / 2));
      if (targetH < naturalH) { gsap.set(contact, { height: targetH }); panel.style.overflowY = 'auto'; }
      gsap.set(contact, { top });

      if (reduce) {
        gsap.set(backdrop, { opacity: 1 });
        gsap.set([...fields, closeBtn], { opacity: 1, y: 0 });
      } else {
        gsap.set(closeBtn, { opacity: 0 });
        gsap.timeline()
          .fromTo(backdrop, { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' }, 0)
          .fromTo(contact, { clipPath: 'inset(0 0 100% 0)' },
            { clipPath: 'inset(0 0 0% 0)', duration: 0.42, ease: 'power3.out' }, 0)
          .fromTo(fields, { opacity: 0, y: 8 },
            { opacity: 1, y: 0, stagger: 0.05, duration: 0.3, ease: 'power2.out' }, 0.18)
          .to(closeBtn, { opacity: 1, duration: 0.25 }, 0.2);
      }
      panel.querySelector<HTMLElement>('input, textarea')?.focus();
    };
    const closeMobile = () => {
      if (reduce) { finishClose(); return; }
      gsap.timeline({ onComplete: finishClose })
        .to([...fields, closeBtn], { opacity: 0, duration: 0.12, ease: 'power1.in' }, 0)
        .to(contact, { clipPath: 'inset(0 0 100% 0)', duration: 0.3, ease: 'power3.in' }, 0.04)
        .to(backdrop, { opacity: 0, duration: 0.26 }, 0.06);
    };

    const openCard = () => {
      if (open) return;
      open = true;
      trigger.setAttribute('aria-expanded', 'true');
      // Measure in place, THEN portal to <body>. The hero subtree clips fixed
      // descendants (.hero-block has a leftover entrance transform → containing
      // block; .hero has overflow:hidden), so the card must live on <body>.
      firstRect = contact.getBoundingClientRect();
      document.body.append(backdrop, contact);
      backdrop.hidden = false;
      if (isMobile()) { openMobile(); return; }
      const { targetW, targetH, scroll } = liftAndMeasure();
      // Only allow scrolling once fully open, and only if the form was clamped
      // to the viewport — otherwise a scrollbar flashes mid-morph.
      const enableScroll = () => { if (scroll) panel.style.overflowY = 'auto'; };

      if (reduce) {
        gsap.set(contact, { width: targetW, height: targetH });
        gsap.set(backdrop, { opacity: 1 });
        gsap.set([...fields, closeBtn], { opacity: 1, y: 0 });
        enableScroll();
      } else {
        // Two-phase: widen first (label slides left), THEN grow tall + reveal fields.
        gsap.set(contact, { width: firstRect!.width, height: firstRect!.height });
        gsap.set(closeBtn, { opacity: 0 });
        gsap.timeline({ onComplete: enableScroll })
          .fromTo(backdrop, { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' }, 0)
          .to(contact, { width: targetW, duration: 0.38, ease: 'power3.out' }, 0)
          .to(contact, { height: targetH, duration: 0.42, ease: 'power3.out' }, 0.32)
          .fromTo(fields, { opacity: 0, y: 8 },
            { opacity: 1, y: 0, stagger: 0.05, duration: 0.3, ease: 'power2.out' }, 0.5)
          .to(closeBtn, { opacity: 1, duration: 0.25 }, 0.5);
      }
      panel.querySelector<HTMLElement>('input, textarea')?.focus();
    };

    const finishClose = () => {
      contact.classList.remove('contact--open');
      gsap.set(contact, { clearProps: 'all' });
      gsap.set(fields, { clearProps: 'opacity,transform' });
      gsap.set(closeBtn, { clearProps: 'opacity,transform' });
      panel.style.overflowY = '';
      backdrop.hidden = true;
      home.append(backdrop, contact); // restore into the hero (original order)
    };

    const closeCard = () => {
      if (!open || !firstRect) return;
      open = false;
      trigger.setAttribute('aria-expanded', 'false');
      trigger.focus();
      panel.style.overflowY = 'hidden'; // no scrollbar during collapse

      if (isMobile()) { closeMobile(); return; }
      if (reduce) { finishClose(); return; }
      // Reverse order: fade fields + close, collapse height, THEN narrow to chip.
      gsap.timeline({ onComplete: finishClose })
        .to([...fields, closeBtn], { opacity: 0, y: 6, duration: 0.15, ease: 'power1.in' }, 0)
        .to(contact, { height: firstRect.height, duration: 0.34, ease: 'power3.in' }, 0.08)
        .to(contact, { width: firstRect.width, duration: 0.3, ease: 'power3.in' }, 0.4)
        .to(backdrop, { opacity: 0, duration: 0.28 }, 0.45);
    };

    trigger.addEventListener('click', () => (open ? closeCard() : openCard()));
    closeBtn.addEventListener('click', closeCard);
    backdrop.addEventListener('click', closeCard);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && open) closeCard(); });

    // ---- form submit ----
    const form = panel.querySelector<HTMLFormElement>('[data-contact-form]');
    const status = panel.querySelector<HTMLElement>('[data-contact-status]');
    const sendBtn = panel.querySelector<HTMLButtonElement>('.contact-send');

    if (form && status && sendBtn) {
      const setStatus = (msg: string, state: '' | 'ok' | 'error') => {
        status.textContent = msg;
        if (state) status.setAttribute('data-state', state); else status.removeAttribute('data-state');
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(form).entries());
        sendBtn.disabled = true;
        setStatus('sending…', '');
        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          const out = await res.json().catch(() => ({}));
          if (res.ok) {
            setStatus('sent — thanks!', 'ok');
            form.reset();
          } else {
            setStatus(out.error || 'something went wrong', 'error');
            sendBtn.disabled = false;
          }
        } catch {
          setStatus('network error — try again', 'error');
          sendBtn.disabled = false;
        }
      });
    }
  }
</script>
