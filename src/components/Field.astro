<canvas class="field-canvas" aria-hidden="true"></canvas>
<div class="vignette" aria-hidden="true"></div>
<style>
  .vignette {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    clip-path: inset(clamp(14px, 1.6vw, 26px));
    /* faint light pool in the centre (shows on dark) + darker edges (shows on light) */
    background:
      radial-gradient(ellipse 70% 65% at 50% 42%, rgba(255,255,255,0.05), transparent 55%),
      radial-gradient(ellipse 100% 100% at 50% 50%, transparent 50%, rgba(0,0,0,0.45) 100%);
    animation: vigBreathe 9s ease-in-out infinite;
  }
  @keyframes vigBreathe { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .vignette { animation: none; } }
</style>
<script>
  import { createGrain } from '../scripts/grain';
  import { THEME_EVENT } from '../scripts/theme';
  const canvas = document.querySelector('canvas.field-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ok = (() => { try { return !!document.createElement('canvas').getContext('webgl'); } catch { return false; } })();
    if (!ok) { canvas.style.display = 'none'; }
    else {
      const color = () => getComputedStyle(document.documentElement).getPropertyValue('--particle').trim() || '#f1efe9';
      const g = createGrain(canvas);
      g.setTheme(color());
      g.start();
      window.addEventListener(THEME_EVENT, () => g.setTheme(color()));
    }
  }
</script>
