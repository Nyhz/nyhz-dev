<canvas class="field-canvas" aria-hidden="true"></canvas>
<script>
  import { createGrain } from '../scripts/grain';
  const canvas = document.querySelector('canvas.field-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ok = (() => { try { return !!document.createElement('canvas').getContext('webgl'); } catch { return false; } })();
    if (!ok) { canvas.style.display = 'none'; }
    else { createGrain(canvas).start(); }
  }
</script>
