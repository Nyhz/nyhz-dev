---
const { socials } = Astro.props;
---
<nav class="socials" data-anim>
  {socials.map((s) => (
    <a href={s.url} target="_blank" rel="noopener noreferrer">{s.label}</a>
  ))}
</nav>
<style>
  .socials { display: flex; gap: 1.5rem; align-items: center; }
  .socials a { color: var(--muted); font-size: 0.85rem; letter-spacing: 0.02em;
    text-transform: lowercase; transition: color 0.2s; }
  .socials a:hover { color: var(--fg); }
</style>
