---
const { name, tagline = 'creative developer' } = Astro.props;
---
<div class="loader" data-loader data-name={name} data-tagline={tagline}>
  <div class="loader__frame" aria-hidden="true">
    <span class="ltk tl"></span><span class="ltk tr"></span>
    <span class="ltk bl"></span><span class="ltk br"></span>
  </div>
  <div class="loader__scan" aria-hidden="true"></div>

  <div class="loader__ui">
    <!-- cryptic boot log (revealed as progress advances) -->
    <div class="loader__log" data-log aria-hidden="true">
      <div>› <span class="hx">0x1f00</span> renderer<span class="ok"> ok</span></div>
      <div>› shaders <span class="hx">0x3a2e</span><span class="ok"> ok</span></div>
      <div>› field·grain <span class="hx">0x9c4</span><span class="ok"> ok</span></div>
      <div>› hydrate <span class="hx">0x04</span> islands<span class="ok"> ok</span></div>
      <div>› ./nyhz —mount<span class="cur"></span></div>
    </div>

    <!-- climax: the name is typed out, with a blinking cursor + chromatic glitch -->
    <div class="loader__name" data-name-wrap aria-hidden="true">
      <div class="loader__center">
        <span class="loader__type" data-type data-text={name}>{name}</span>
      </div>
    </div>

    <h1 class="loader__sr" aria-label={name}>{name}</h1>

    <div class="loader__counter"><span data-count>000</span><i>%</i></div>
    <div class="loader__bar-wrap"><span class="loader__bar" data-bar></span></div>
  </div>
</div>

<noscript><style>.loader { display: none !important; }</style></noscript>

<style>
  .loader {
    position: fixed; inset: 0; z-index: 100; overflow: hidden;
    background: #0a0a0a; color: #f1efe9;
    --mono: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, monospace;
    --accent: #3ad29f;
  }
  .loader__sr { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }

  .loader__frame { position: absolute; inset: clamp(14px, 1.6vw, 26px); border: 1px solid #2b2b27; z-index: 3; }
  .ltk { position: absolute; width: 9px; height: 9px; border: 1px solid #f1efe9; }
  .ltk.tl { left: -1px; top: -1px; border-right: 0; border-bottom: 0; }
  .ltk.tr { right: -1px; top: -1px; border-left: 0; border-bottom: 0; }
  .ltk.bl { left: -1px; bottom: -1px; border-right: 0; border-top: 0; }
  .ltk.br { right: -1px; bottom: -1px; border-left: 0; border-top: 0; }

  .loader__scan { position: absolute; inset: 0; z-index: 4; pointer-events: none; opacity: 0.5;
    mix-blend-mode: overlay; animation: lflick 2.4s steps(2) infinite;
    background:
      repeating-linear-gradient(0deg, rgba(180,180,180,0.10) 0 1px, transparent 1px 3px),
      radial-gradient(circle at 50% 50%, transparent 52%, rgba(0,0,0,0.5) 100%); }
  @keyframes lflick { 0%,94%,100% { opacity: 0.5; } 95% { opacity: 0.9; } 97% { opacity: 0.25; } }

  .loader__ui { position: absolute; inset: 0; z-index: 5; pointer-events: none; }

  /* ---- boot log ---- */
  .loader__log { position: absolute; left: clamp(26px, 5vw, 64px); top: clamp(64px, 12vh, 130px);
    font: 500 clamp(12px, 1.2vw, 14.5px) var(--mono); letter-spacing: 0.04em; color: #76766f;
    transition: opacity 0.35s ease; line-height: 1.7; }
  .loader__log div { opacity: 0; transform: translateY(3px); transition: opacity 0.25s ease, transform 0.25s ease; }
  .loader__log div.in { opacity: 1; transform: none; }
  .loader__log .hx { color: #4a4a44; }
  .loader__log .ok { color: var(--accent); }
  .loader__log .cur { display: inline-block; width: 7px; height: 1em; background: var(--accent);
    margin-left: 3px; vertical-align: -2px; animation: lblink 0.85s steps(1) infinite; }
  .loader__log.out { opacity: 0; }
  /* micro-glitch flicker on the log while loading */
  .loader.flick .loader__log { transform: translateX(-2px); text-shadow: -1px 0 #ff2e63, 1px 0 #2ee6ff; }

  /* ---- typed name (climax) ---- */
  .loader__name { position: absolute; inset: 0; display: grid; place-content: center;
    opacity: 0; transition: opacity 0.3s ease; }
  .loader__name.in { opacity: 1; }
  /* matches .hero-name exactly so the fly-to-hero handoff is seamless */
  .loader__center { width: 4ch; font: 700 clamp(3.2rem, 9.5vw, 7rem)/1 var(--mono); letter-spacing: -0.02em; }
  .loader__type { position: relative; display: block; width: 0; overflow: hidden; white-space: nowrap;
    border-right: 0.07em solid var(--accent); animation: lblink 0.8s steps(1) infinite; }
  .loader__type.typed { overflow: visible; } /* let glitch/shatter spill out once written */
  .loader__type::before, .loader__type::after { content: attr(data-text); position: absolute; left: 0; top: 0;
    opacity: 0; pointer-events: none; }
  .loader__type::before { color: #ff2e63; }
  .loader__type::after  { color: #2ee6ff; }
  /* held chromatic jitter (subtle, occasional) */
  .loader__name.glitch .loader__type::before { animation: lgR 2.6s steps(1) infinite; }
  .loader__name.glitch .loader__type::after  { animation: lgC 2.6s steps(1) infinite; }
  @keyframes lgR { 0%,8%{opacity:0;transform:translate(0,0)} 9%{opacity:.85;transform:translate(-3px,1px)}
    12%,57%{opacity:0} 58%{opacity:.85;transform:translate(-2px,-1px)} 61%,100%{opacity:0} }
  @keyframes lgC { 0%,8%{opacity:0;transform:translate(0,0)} 9%{opacity:.85;transform:translate(3px,-1px)}
    12%,57%{opacity:0} 58%{opacity:.85;transform:translate(2px,1px)} 61%,100%{opacity:0} }
  @keyframes lblink { 0%,50% { opacity: 1; border-right-color: var(--accent); } 50.01%,100% { opacity: 1; border-right-color: transparent; } }

  /* ---- counter + bar ---- */
  .loader__counter { position: absolute; left: clamp(26px, 2.6vw, 42px); bottom: clamp(22px, 2.4vw, 38px);
    font: 700 clamp(2.2rem, 7vw, 4.4rem) var(--mono); font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em; line-height: 1; color: #f1efe9; }
  .loader__counter i { font-style: normal; font-size: 0.36em; color: #76766f; margin-left: 0.3em; }
  .loader__bar-wrap { position: absolute; left: 0; bottom: 0; width: 100%; height: 2px; background: #2b2b27; }
  .loader__bar { display: block; width: 100%; height: 100%; background: #f1efe9;
    transform: scaleX(0); transform-origin: left center; }

  @media (prefers-reduced-motion: reduce) {
    .loader__scan, .loader__log .cur, .loader__type { animation: none; }
    .loader__type { border-right-color: transparent; }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const loader = document.querySelector('[data-loader]') as HTMLElement;
  const countEl = document.querySelector('[data-count]') as HTMLElement;
  const barEl = document.querySelector('[data-bar]') as HTMLElement;
  const logEl = document.querySelector('[data-log]') as HTMLElement;
  const logLines = Array.from(logEl.children) as HTMLElement[];
  const nameWrap = document.querySelector('[data-name-wrap]') as HTMLElement;
  const centerEl = nameWrap.querySelector('.loader__center') as HTMLElement;
  const typeEl = document.querySelector('[data-type]') as HTMLElement;
  const frameEl = loader.querySelector('.loader__frame') as HTMLElement;
  const scanEl = loader.querySelector('.loader__scan') as HTMLElement;
  const counterEl = loader.querySelector('.loader__counter') as HTMLElement;
  const barWrap = loader.querySelector('.loader__bar-wrap') as HTMLElement;
  const NAME = loader.dataset.name || 'nyhz';
  const anims = gsap.utils.toArray<HTMLElement>('[data-anim]');

  gsap.set(anims, { opacity: 0, y: 16 });

  function revealSite() {
    gsap.to(anims, {
      opacity: 1, y: 0, duration: reduce ? 0 : 0.8, stagger: reduce ? 0 : 0.07,
      ease: 'power2.out', delay: reduce ? 0 : 0.1,
    });
    window.dispatchEvent(new Event('loaderdone'));
  }

  // Fly the typed loader name to the hero name's spot, hand off to the real
  // (identical, mono) hero wordmark, and reveal the site. The page's own frame
  // sits underneath, so the frame stays continuous.
  function flyToHero() {
    typeEl.style.borderRightColor = 'transparent'; // drop the caret
    const hero = document.querySelector('.hero-name') as HTMLElement | null;
    if (!hero) {
      gsap.timeline({ onComplete: () => gsap.set(loader, { display: 'none' }) })
        .to(loader, { opacity: 0, duration: 0.5, ease: 'power2.inOut' })
        .add(revealSite, 0.1);
      return;
    }
    const src = centerEl.getBoundingClientRect();
    const tr = hero.getBoundingClientRect();
    const scale = tr.height / src.height;
    const dx = tr.left - src.left;
    const dy = (tr.top - 16) - src.top; // undo the entrance y:16 → target the FINAL spot

    gsap.timeline()
      .to([frameEl, scanEl, logEl, counterEl, barWrap], { opacity: 0, duration: 0.45, ease: 'power2.in' }, 0)
      .to(loader, { backgroundColor: 'rgba(10,10,10,0)', duration: 0.5, ease: 'power2.in' }, 0.1)
      .to(centerEl, { x: dx, y: dy, scale, transformOrigin: 'top left', duration: 0.7, ease: 'power3.inOut' }, 0)
      .add(revealSite, 0.2)                                  // hero name fades into place under the flier
      .to(centerEl, { opacity: 0, duration: 0.25, ease: 'power2.out' }, 0.68) // crossfade onto the real one
      .set(loader, { display: 'none' });
  }

  if (reduce) {
    logLines.forEach((l) => l.classList.add('in'));
    countEl.textContent = '100';
    barEl.style.transform = 'scaleX(1)';
    typeEl.style.width = NAME.length + 'ch';
    nameWrap.classList.add('in');
    logEl.classList.add('out');
    loader.style.display = 'none';
    revealSite();
  } else {
    // Micro-glitch flicker while loading.
    const flick = setInterval(() => {
      loader.classList.add('flick');
      setTimeout(() => loader.classList.remove('flick'), 60);
    }, 260 + Math.random() * 220);

    const state = { p: 0 };
    const typer = { c: 0 };
    const tick = () => {
      countEl.textContent = String(Math.round(state.p)).padStart(3, '0');
      barEl.style.transform = `scaleX(${state.p / 100})`;
    };

    gsap.set(logLines, { opacity: 0, y: 4 });

    const tl = gsap.timeline();
    // Log lines reveal slowly + evenly, independent of the eased counter.
    tl.to(logLines, { opacity: 1, y: 0, duration: 0.4, stagger: 0.42, ease: 'power2.out' }, 0);
    // Counter runs concurrently: slow start → acceleration → ease off.
    tl.to(state, { p: 85, duration: 1.7, ease: 'power3.in', onUpdate: tick }, 0);
    tl.to(state, { p: 100, duration: 0.9, ease: 'power2.out', onUpdate: tick }, 1.7);

    // finale: fade the log, type the name, then let it glitch + hold
    tl.add(() => { logEl.classList.add('out'); nameWrap.classList.add('in'); }, '>+0.05');
    tl.to(typer, { c: NAME.length, duration: 0.55, ease: `steps(${NAME.length})`,
      onUpdate() { typeEl.style.width = Math.round(typer.c) + 'ch'; } });
    tl.add(() => { typeEl.classList.add('typed'); nameWrap.classList.add('glitch'); });
    tl.to({}, { duration: 0.5 }); // hold

    // exit — fly the name to the hero
    tl.call(() => clearInterval(flick));
    tl.add(flyToHero);
  }
</script>
