---
const { name, tagline = 'creative developer' } = Astro.props;
---
<div class="loader" data-loader data-name={name} data-tagline={tagline}>
  <canvas class="loader__gl" aria-hidden="true"></canvas>
  <h1 class="loader__fallback" data-fallback data-text={name} aria-label={name}>{name}</h1>

  <div class="loader__frame" aria-hidden="true">
    <span class="ltk tl"></span><span class="ltk tr"></span>
    <span class="ltk bl"></span><span class="ltk br"></span>
  </div>
  <div class="loader__scan" aria-hidden="true"></div>

  <div class="loader__ui">
    <span class="lmeta b">v2 — 2026</span>
    <p class="loader__status"><span data-status></span></p>
    <div class="loader__counter"><span data-count>000</span><i>%</i></div>
    <div class="loader__bar-wrap"><span class="loader__bar" data-bar></span></div>
  </div>
</div>

<noscript><style>.loader { display: none !important; }</style></noscript>

<style>
  .loader {
    position: fixed; inset: 0; z-index: 100; overflow: hidden;
    background: #0a0a0a; color: #f1efe9;
    --mono: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, monospace;
  }
  .loader__gl { position: absolute; inset: 0; z-index: 2; display: block; width: 100%; height: 100%; }

  /* DOM fallback name (only shown when WebGL is unavailable). */
  .loader__fallback { display: none; position: absolute; inset: 0; z-index: 2;
    align-items: center; justify-content: center; font-weight: 700;
    font-size: clamp(3rem, 14vw, 10rem); letter-spacing: -0.05em; }
  .loader.no-webgl .loader__fallback { display: flex; }
  .loader.no-webgl .loader__fallback::before,
  .loader.no-webgl .loader__fallback::after {
    content: attr(data-text); position: absolute; inset: 0; display: flex;
    align-items: center; justify-content: center; }
  .loader.no-webgl .loader__fallback::before { color: #ff2e63; animation: fbR 0.9s steps(2) infinite; }
  .loader.no-webgl .loader__fallback::after { color: #2ee6ff; animation: fbC 0.9s steps(2) infinite; }
  @keyframes fbR { 0%,100% { transform: translate(0,0); } 50% { transform: translate(-4px,1px); } }
  @keyframes fbC { 0%,100% { transform: translate(0,0); } 50% { transform: translate(4px,-1px); } }

  .loader__frame { position: absolute; inset: clamp(14px, 1.6vw, 26px); border: 1px solid #2b2b27; z-index: 3; }
  .ltk { position: absolute; width: 9px; height: 9px; border: 1px solid #f1efe9; }
  .ltk.tl { left: -1px; top: -1px; border-right: 0; border-bottom: 0; }
  .ltk.tr { right: -1px; top: -1px; border-left: 0; border-bottom: 0; }
  .ltk.bl { left: -1px; bottom: -1px; border-right: 0; border-top: 0; }
  .ltk.br { right: -1px; bottom: -1px; border-left: 0; border-top: 0; }

  .loader__scan { position: absolute; inset: 0; z-index: 4; pointer-events: none; opacity: 0.55;
    mix-blend-mode: overlay; animation: lflick 2.4s steps(2) infinite;
    background:
      repeating-linear-gradient(0deg, rgba(180,180,180,0.10) 0 1px, transparent 1px 3px),
      radial-gradient(circle at 50% 50%, transparent 52%, rgba(0,0,0,0.5) 100%); }
  @keyframes lflick { 0%,94%,100% { opacity: 0.55; } 95% { opacity: 0.95; } 97% { opacity: 0.28; } }

  .loader__ui { position: absolute; inset: 0; z-index: 5; pointer-events: none; }
  .lmeta { position: absolute; top: clamp(22px, 2.4vw, 38px); font: 500 0.62rem var(--mono);
    letter-spacing: 0.16em; text-transform: uppercase; color: #76766f; }
  .lmeta.a { left: clamp(26px, 2.6vw, 42px); color: #f1efe9; }
  .lmeta.b { right: clamp(26px, 2.6vw, 42px); }
  .loader__status { position: absolute; left: 0; right: 0; top: 72%; text-align: center;
    font: 500 0.72rem var(--mono); letter-spacing: 0.34em; color: #76766f; }
  .loader__counter { position: absolute; left: clamp(26px, 2.6vw, 42px); bottom: clamp(22px, 2.4vw, 38px);
    font: 700 clamp(2.4rem, 8vw, 5rem) var(--mono); font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em; line-height: 1; }
  .loader__counter i { font-style: normal; font-size: 0.36em; color: #76766f; margin-left: 0.3em; }
  .loader__bar-wrap { position: absolute; left: 0; bottom: 0; width: 100%; height: 2px; background: #2b2b27; }
  .loader__bar { display: block; width: 100%; height: 100%; background: #f1efe9;
    transform: scaleX(0); transform-origin: left center; }

  @media (max-width: 520px) { .lmeta { display: none; } }
  @media (prefers-reduced-motion: reduce) {
    .loader__scan, .loader.no-webgl .loader__fallback::before,
    .loader.no-webgl .loader__fallback::after { animation: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { createGlitchName } from '../scripts/loader-gl';

  const GLYPHS = 'ABCDEFGHJKLMNPQRSTUVWXYZ0123456789#%&/<>*+=';
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const loader = document.querySelector('[data-loader]') as HTMLElement;
  const target = (loader.dataset.tagline || '').toLowerCase();
  const glCanvas = document.querySelector('.loader__gl') as HTMLCanvasElement;
  const countEl = document.querySelector('[data-count]') as HTMLElement;
  const barEl = document.querySelector('[data-bar]') as HTMLElement;
  const statusEl = document.querySelector('[data-status]') as HTMLElement;
  const anims = gsap.utils.toArray<HTMLElement>('[data-anim]');

  gsap.set(anims, { opacity: 0, y: 16 });

  const webglOk = (() => { try { return !!document.createElement('canvas').getContext('webgl'); } catch { return false; } })();
  let gl: { start(): void; setAmt(v: number): void; dispose(): void } | null = null;
  if (webglOk) {
    try { gl = createGlitchName(glCanvas, loader.dataset.name || 'nyhz'); } catch { gl = null; }
  }
  if (gl) gl.start(); else loader.classList.add('no-webgl');

  function scramble(p: number): string {
    let out = '';
    for (let k = 0; k < target.length; k++) {
      const ch = target[k];
      if (ch === ' ') { out += ' '; continue; }
      out += p >= (k + 1) / target.length ? ch : GLYPHS[(Math.random() * GLYPHS.length) | 0];
    }
    return out;
  }

  function revealSite() {
    gsap.to(anims, {
      opacity: 1, y: 0, duration: reduce ? 0 : 0.8, stagger: reduce ? 0 : 0.07,
      ease: 'power2.out', delay: reduce ? 0 : 0.1,
    });
    window.dispatchEvent(new Event('loaderdone'));
  }

  if (reduce) {
    statusEl.textContent = target;
    gl?.setAmt(0);
    loader.style.display = 'none';
    gl?.dispose();
    revealSite();
  } else {
    // Constant glitch flicker while loading.
    const burst = setInterval(() => gl?.setAmt(0.12 + Math.random() * 0.22), 150);
    const state = { p: 0 };
    const amt = { v: 0.15 };
    const tl = gsap.timeline();

    const tick = () => {
      const v = Math.round(state.p);
      countEl.textContent = String(v).padStart(3, '0');
      statusEl.textContent = scramble(state.p / 100);
      barEl.style.transform = `scaleX(${state.p / 100})`;
    };
    // slow start → strong acceleration, then ease off over the last 10
    tl.to(state, { p: 90, duration: 1.55, ease: 'power3.in', onUpdate: tick });
    tl.to(state, { p: 100, duration: 0.75, ease: 'power2.out', onUpdate: tick,
      onComplete() { statusEl.textContent = target; } });

    // Exit — shatter the name, fade the readout, then fade the whole loader
    // out. The page carries its own identical frame underneath, so the frame
    // appears continuous (no expand / re-appear).
    tl.addLabel('out', '+=0.2');
    tl.call(() => clearInterval(burst), [], 'out');
    tl.to(amt, { v: 0.85, duration: 0.5, ease: 'power2.in', onUpdate() { gl?.setAmt(amt.v); } }, 'out');
    tl.to('[data-loader] .loader__ui', { opacity: 0, duration: 0.3, ease: 'power2.in' }, 'out+=0.1');
    tl.set(loader, { pointerEvents: 'none' });
    tl.to(loader, { opacity: 0, duration: 0.55, ease: 'power2.inOut' }, 'out+=0.3');
    tl.add(revealSite, 'out+=0.45');
    tl.set(loader, { display: 'none' });
    tl.call(() => gl?.dispose());
  }
</script>
