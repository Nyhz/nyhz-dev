---
const { name } = Astro.props;
const chars = [...name];
const PANELS = 7;
---
<div class="loader" data-loader>
  <div class="loader__panels" aria-hidden="true">
    {Array.from({ length: PANELS }).map(() => <span class="panel"></span>)}
  </div>

  <div class="loader__content">
    <h1 class="loader__name" aria-label={name}>
      {chars.map((ch) => (
        <span class="char"><span class="char-inner">{ch === ' ' ? ' ' : ch}</span></span>
      ))}
    </h1>
    <p class="loader__status"><span data-status>initializing</span></p>
  </div>

  <div class="loader__counter"><span data-count>000</span><i>%</i></div>
  <div class="loader__bar-wrap"><span class="loader__bar" data-bar></span></div>
</div>

<noscript><style>.loader { display: none !important; }</style></noscript>

<style>
  .loader {
    position: fixed; inset: 0; z-index: 100;
    --mono: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, monospace;
    color: var(--fg);
  }
  .loader__panels { position: absolute; inset: 0; display: flex; z-index: 1; }
  .panel { flex: 1 1 0; background: var(--bg); will-change: transform; }

  .loader__content {
    position: absolute; inset: 0; z-index: 2;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 1.5rem; pointer-events: none;
  }
  .loader__name {
    display: flex; font-weight: 600; line-height: 0.9;
    font-size: clamp(3rem, 13vw, 9rem); letter-spacing: -0.05em;
  }
  .char { display: inline-block; overflow: hidden; }
  .char-inner { display: inline-block; will-change: transform; }

  .loader__status {
    font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.32em;
    text-transform: uppercase; color: var(--muted);
  }

  .loader__counter {
    position: absolute; left: var(--space); bottom: calc(var(--space) - 0.4rem); z-index: 2;
    font-family: var(--mono); font-size: clamp(2.2rem, 7vw, 4.5rem);
    font-variant-numeric: tabular-nums; letter-spacing: -0.02em; line-height: 1;
  }
  .loader__counter i { font-style: normal; font-size: 0.4em; color: var(--muted); margin-left: 0.25em; }

  .loader__bar-wrap {
    position: absolute; left: 0; bottom: 0; width: 100%; height: 2px; z-index: 2;
    background: var(--line);
  }
  .loader__bar {
    display: block; width: 100%; height: 100%; background: var(--fg);
    transform: scaleX(0); transform-origin: left center; will-change: transform;
  }
</style>

<script>
  import { gsap } from 'gsap';

  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const loader = document.querySelector('[data-loader]') as HTMLElement;
  const countEl = document.querySelector('[data-count]') as HTMLElement;
  const barEl = document.querySelector('[data-bar]') as HTMLElement;
  const statusEl = document.querySelector('[data-status]') as HTMLElement;
  const charInners = gsap.utils.toArray<HTMLElement>('[data-loader] .char-inner');
  const panels = gsap.utils.toArray<HTMLElement>('[data-loader] .panel');
  const anims = gsap.utils.toArray<HTMLElement>('[data-anim]');

  // Site content starts hidden in JS (so it stays visible if JS never runs).
  gsap.set(anims, { opacity: 0, y: 14 });

  function statusFor(p: number): string {
    if (p < 25) return 'initializing';
    if (p < 55) return 'compiling shaders';
    if (p < 80) return 'warming particles';
    if (p < 100) return 'almost there';
    return 'ready';
  }

  function revealSite() {
    gsap.to(anims, {
      opacity: 1, y: 0,
      duration: reduce ? 0 : 0.7, stagger: reduce ? 0 : 0.08,
      ease: 'power2.out', delay: reduce ? 0 : 0.1,
    });
    window.dispatchEvent(new Event('loaderdone'));
  }

  if (reduce) {
    loader.style.display = 'none';
    revealSite();
  } else {
    gsap.set(charInners, { yPercent: 115 });
    const state = { p: 0 };
    const tl = gsap.timeline();

    // Intro — name rises in by character.
    tl.to(charInners, { yPercent: 0, duration: 0.75, stagger: 0.06, ease: 'power3.out' }, 0.1);

    // Progress — counter, status, and bar driven by one tween.
    tl.to(state, {
      p: 100, duration: 1.6, ease: 'power1.inOut',
      onUpdate() {
        const v = Math.round(state.p);
        countEl.textContent = String(v).padStart(3, '0');
        statusEl.textContent = statusFor(v);
        barEl.style.transform = `scaleX(${state.p / 100})`;
      },
    }, 0.25);

    // Outro — fade the readout, stop blocking clicks, then lift the blinds.
    tl.to('[data-loader] .loader__content, [data-loader] .loader__counter, [data-loader] .loader__bar-wrap',
      { opacity: 0, duration: 0.4, ease: 'power2.in' }, '+=0.2');
    tl.set(loader, { pointerEvents: 'none' });
    tl.to(panels, { yPercent: -100, duration: 0.85, stagger: 0.05, ease: 'power4.inOut' }, '-=0.05');

    // Reveal the site as the blinds open.
    tl.add(revealSite, '-=0.55');
    tl.set(loader, { display: 'none' });
  }
</script>
