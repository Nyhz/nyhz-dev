---
---
<div class="preview" data-anim>
  <div class="pv__head">
    <button class="pv__back" data-back type="button"><span aria-hidden="true">←</span> back</button>
    <p class="sec-label sec-label--r">— preview</p>
  </div>

  <div class="pv__frame" data-frame>
    <div class="pv__card" data-card>
      <div class="pv__media">
        <img class="pv__img" data-img alt="" hidden />
        <div class="pv__ph" data-ph hidden><span data-ph-title></span></div>
      </div>
      <div class="pv__info">
        <span class="pv__tags" data-tags></span>
        <nav class="pv__links">
          <a class="pv__link" data-repo target="_blank" rel="noopener noreferrer" hidden>repo <span class="ar" aria-hidden="true">↗</span></a>
          <a class="pv__link" data-live target="_blank" rel="noopener noreferrer" hidden>live <span class="ar" aria-hidden="true">↗</span></a>
        </nav>
      </div>
    </div>
  </div>
</div>

<style>
  .preview { width: 100%; }
  .pv__head { display: flex; align-items: baseline; justify-content: flex-end; }
  .pv__back { display: none; background: none; border: none; cursor: pointer; padding: 0;
    font: 500 0.66rem var(--mono); letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted);
    transition: color 0.2s; }
  .pv__back:hover { color: var(--fg); }

  /* the card is hidden until a project is hovered; the frame reserves its space
     (media aspect + info min-height) so nothing shifts when it appears */
  .pv__frame { width: 100%; }
  .pv__card { opacity: 0; will-change: transform, opacity; }

  .pv__media { position: relative; width: 100%; aspect-ratio: 16 / 10; overflow: hidden;
    border: 1px solid var(--line); }
  .pv__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .pv__ph { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    background: repeating-linear-gradient(135deg, var(--line) 0 1px, transparent 1px 12px); }
  .pv__ph span { font-size: clamp(1.1rem, 2.4vw, 1.6rem); font-weight: 600; letter-spacing: -0.02em;
    color: var(--fg); background: var(--bg); padding: 0.2rem 0.7rem; }

  .pv__info { margin-top: 0.9rem; min-height: 3rem; display: flex; flex-direction: column;
    align-items: flex-end; text-align: right; gap: 0.7rem; }
  .pv__tags { font: 0.74rem var(--mono); color: var(--muted); letter-spacing: 0.02em;
    max-width: 100%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .pv__links { display: flex; gap: 1.4rem; }
  .pv__link { position: relative; display: inline-flex; align-items: center; gap: 0.35rem;
    font: 0.8rem var(--mono); color: var(--muted); padding-bottom: 4px; transition: color 0.25s; }
  .pv__link .ar { font-size: 0.85em; opacity: 0.5; transition: transform 0.25s, opacity 0.25s; }
  .pv__link::after { content: ""; position: absolute; left: 0; bottom: 0; width: 100%; height: 1px;
    background: currentColor; transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease; }
  .pv__link:hover { color: var(--fg); }
  .pv__link:hover .ar { transform: translate(2px, -2px); opacity: 1; }
  .pv__link:hover::after { transform: scaleX(1); }
  .pv__link[hidden] { display: none; }

  @media (max-width: 720px) {
    .pv__back { display: inline-flex; gap: 0.4rem; }
    .pv__info { align-items: flex-start; text-align: left; }
    .sec-label--r { text-align: left; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pv__link, .pv__link .ar { transition: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const pv = document.querySelector('.preview');
  const card = pv?.querySelector('[data-card]') as HTMLElement | null;
  const img = pv?.querySelector('[data-img]') as HTMLImageElement | null;
  const ph = pv?.querySelector('[data-ph]') as HTMLElement | null;
  const phTitle = pv?.querySelector('[data-ph-title]') as HTMLElement | null;
  const tags = pv?.querySelector('[data-tags]') as HTMLElement | null;
  const repo = pv?.querySelector('[data-repo]') as HTMLAnchorElement | null;
  const live = pv?.querySelector('[data-live]') as HTMLAnchorElement | null;
  const track = document.querySelector('[data-track]') as HTMLElement | null;
  const back = document.querySelector('[data-back]');
  const rows = Array.from(document.querySelectorAll<HTMLElement>('.prj[data-proj]'));
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = () => matchMedia('(max-width: 720px)').matches;

  function setContent(d: DOMStringMap) {
    const cover = d.cover || '', title = d.title || '';
    if (cover && img && ph) { img.src = cover; img.alt = title; img.hidden = false; ph.hidden = true; }
    else if (img && ph) { img.hidden = true; ph.hidden = false; if (phTitle) phTitle.textContent = title; }
    if (tags) tags.textContent = d.tags || '';
    if (repo) { if (d.repo) { repo.href = d.repo; repo.hidden = false; } else repo.hidden = true; }
    if (live) { if (d.live) { live.href = d.live; live.hidden = false; } else live.hidden = true; }
  }

  let current: string | null = null;
  let tl: gsap.core.Timeline | null = null;

  function show(slug: string, d: DOMStringMap) {
    if (!card || slug === current) return;
    const first = current === null;
    current = slug;
    tl?.kill();
    if (reduce) { setContent(d); gsap.set(card, { opacity: 1, x: 0 }); return; }
    tl = gsap.timeline();
    if (first) {
      setContent(d);
      tl.fromTo(card, { opacity: 0, x: -40 }, { opacity: 1, x: 0, duration: 0.5, ease: 'power3.out' });
    } else {
      // sequenced: current slides OUT to the left (swap only AFTER it finishes),
      // then the next slides IN from the left moving right.
      tl.to(card, {
        opacity: 0, x: -40, duration: 0.32, ease: 'power2.out',
        onComplete: () => setContent(d),
      });
      tl.fromTo(card, { opacity: 0, x: -40 }, { opacity: 1, x: 0, duration: 0.46, ease: 'power3.out' });
    }
  }

  function setHeight() {
    if (!track) return;
    if (!isMobile()) { track.style.height = ''; return; }
    const active = track.classList.contains('is-preview')
      ? document.querySelector('.preview') : document.querySelector('.projects');
    if (active) track.style.height = (active as HTMLElement).offsetHeight + 'px';
  }

  rows.forEach((r) => {
    const slug = r.dataset.proj!;
    r.addEventListener('mouseenter', () => { if (!isMobile()) show(slug, r.dataset); });
    r.addEventListener('focusin', () => { if (!isMobile()) show(slug, r.dataset); });
    r.querySelector('a')?.addEventListener('click', (e) => {
      if (isMobile()) { e.preventDefault(); show(slug, r.dataset); track?.classList.add('is-preview'); setHeight(); }
    });
  });
  back?.addEventListener('click', () => { track?.classList.remove('is-preview'); setHeight(); });
  addEventListener('resize', setHeight);
  setHeight();
</script>
