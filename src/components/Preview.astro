---
---
<div class="preview" data-anim>
  <div class="pv__head">
    <button class="pv__back" data-back type="button"><span aria-hidden="true">←</span> back</button>
    <p class="sec-label sec-label--r">— preview</p>
  </div>

  <div class="pv__frame" data-frame>
    <div class="pv__card" data-card>
      <div class="pv__dossier">
        <p class="pv__d-title"><span data-title-t></span><i class="pv__caret" aria-hidden="true"></i></p>
        <pre class="pv__d-body"><span data-body-t></span><i class="pv__caret" aria-hidden="true"></i></pre>
      </div>
      <nav class="pv__links">
        <a class="pv__link" data-repo target="_blank" rel="noopener noreferrer" hidden>github <span class="ar" aria-hidden="true">↗</span></a>
        <a class="pv__link" data-live target="_blank" rel="noopener noreferrer" hidden>live <span class="ar" aria-hidden="true">↗</span></a>
        <a class="pv__link" data-download target="_blank" rel="noopener noreferrer" hidden>download <span class="ar" aria-hidden="true">↓</span></a>
      </nav>
    </div>
  </div>
</div>

<style>
  .preview { width: 100%; }
  .pv__head { display: flex; align-items: baseline; justify-content: flex-end; }
  .preview .sec-label { opacity: 0; transition: opacity 0.35s ease; }
  .preview.pv-active .sec-label { opacity: 1; }
  .pv__back { display: none; background: none; border: none; cursor: pointer; padding: 0;
    font: 500 0.66rem var(--mono); letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted);
    transition: color 0.2s; }
  .pv__back:hover { color: var(--fg); }

  .pv__frame { width: 100%; }
  .pv__card { opacity: 0; will-change: transform, opacity; }

  /* terminal dossier — typed out, teal caret marks position. A single faint
     scanline keeps it on-brand without the loud loader glitch. */
  .pv__dossier { position: relative; min-height: 12rem; overflow: hidden;
    border: 1px solid var(--line); padding: 1.1rem 1.2rem; }
  .pv__dossier::after { content: ""; position: absolute; inset: 0; pointer-events: none; opacity: 0.4;
    background: repeating-linear-gradient(0deg, rgba(180,180,180,0.05) 0 1px, transparent 1px 3px); }
  .pv__d-title { font: 700 1.05rem var(--mono); letter-spacing: -0.01em; color: var(--fg);
    margin: 0 0 0.75rem; min-height: 1.3em; }
  .pv__d-body { font: 0.82rem/1.7 var(--mono); color: var(--dim); white-space: pre-wrap;
    margin: 0; min-height: 6.5rem; }
  .pv__caret { display: none; width: 0.5em; height: 1.05em; background: #3ad29f;
    vertical-align: -0.16em; margin-left: 2px; }
  .typing > .pv__caret { display: inline-block; animation: pvBlink 0.8s steps(1) infinite; }
  @keyframes pvBlink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }

  .pv__links { display: flex; gap: 1.4rem; margin-top: 1rem; }
  .pv__link { position: relative; display: inline-flex; align-items: center; gap: 0.35rem;
    font: 0.8rem var(--mono); color: var(--muted); padding-bottom: 4px; transition: color 0.25s; }
  .pv__link .ar { font-size: 0.85em; opacity: 0.5; transition: transform 0.25s, opacity 0.25s; }
  .pv__link::after { content: ""; position: absolute; left: 0; bottom: 0; width: 100%; height: 1px;
    background: currentColor; transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease; }
  .pv__link:hover { color: var(--fg); }
  .pv__link:hover .ar { transform: translate(2px, -2px); opacity: 1; }
  .pv__link:hover::after { transform: scaleX(1); }
  .pv__link[hidden] { display: none; }

  @media (max-width: 720px) {
    .pv__head { justify-content: space-between; }
    .pv__back { display: inline-flex; gap: 0.4rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pv__link, .pv__link .ar { transition: none; }
    .typing > .pv__caret { animation: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const pv = document.querySelector('.preview');
  const card = pv?.querySelector('[data-card]') as HTMLElement | null;
  const titleEl = pv?.querySelector('.pv__d-title') as HTMLElement | null;
  const bodyEl = pv?.querySelector('.pv__d-body') as HTMLElement | null;
  const titleT = pv?.querySelector('[data-title-t]') as HTMLElement | null;
  const bodyT = pv?.querySelector('[data-body-t]') as HTMLElement | null;
  const linksEl = pv?.querySelector('.pv__links') as HTMLElement | null;
  const repo = pv?.querySelector('[data-repo]') as HTMLAnchorElement | null;
  const live = pv?.querySelector('[data-live]') as HTMLAnchorElement | null;
  const download = pv?.querySelector('[data-download]') as HTMLAnchorElement | null;
  const track = document.querySelector('[data-track]') as HTMLElement | null;
  const back = document.querySelector('[data-back]');
  const rows = Array.from(document.querySelectorAll<HTMLElement>('.prj[data-proj]'));
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = () => matchMedia('(max-width: 720px)').matches;

  const bodyOf = (d: DOMStringMap) => {
    const status = d.live ? 'live' : d.download ? 'download' : 'personal · source';
    return `${d.desc || ''}\n\nstack    ${d.tags || ''}\nstatus   ${status}`;
  };
  function setLinks(d: DOMStringMap) {
    if (repo) { if (d.repo) { repo.href = d.repo; repo.hidden = false; } else repo.hidden = true; }
    if (live) { if (d.live) { live.href = d.live; live.hidden = false; } else live.hidden = true; }
    if (download) { if (d.download) { download.href = d.download; download.hidden = false; } else download.hidden = true; }
  }
  function reset() {
    if (titleT) titleT.textContent = '';
    if (bodyT) bodyT.textContent = '';
    titleEl?.classList.remove('typing');
    bodyEl?.classList.remove('typing');
    if (linksEl) gsap.set(linksEl, { opacity: 0 });
  }

  let current: string | null = null;
  let tl: gsap.core.Timeline | null = null;

  function enterIn(t: gsap.core.Timeline) {
    t.fromTo(card, { opacity: 0, x: -40 },
      { opacity: 1, x: 0, duration: 0.6, ease: 'back.out(2.4)', immediateRender: false });
  }
  function leaveOut(t: gsap.core.Timeline, after?: () => void) {
    t.to(card, { x: 26, duration: 0.18, ease: 'power2.out' });
    t.to(card, { x: -170, opacity: 0, duration: 0.38, ease: 'power3.in', onComplete: after });
  }

  function typeInto(t: gsap.core.Timeline, host: HTMLElement, span: HTMLElement, text: string, per: number) {
    const s = { i: 0 };
    t.add(() => { host.classList.add('typing'); span.textContent = ''; });
    t.to(s, { i: text.length, duration: Math.max(0.18, text.length * per),
      ease: `steps(${Math.max(1, text.length)})`,
      onUpdate() { span.textContent = text.slice(0, Math.round(s.i)); } });
  }

  // Type the dossier: title, then body (keeps the teal caret blinking at the end),
  // then fade the links in.
  function typeDossier(t: gsap.core.Timeline, d: DOMStringMap) {
    if (!titleEl || !bodyEl || !titleT || !bodyT || !linksEl) return;
    setLinks(d);
    typeInto(t, titleEl, titleT, d.title || '', 0.03);
    t.add(() => titleEl.classList.remove('typing'));
    typeInto(t, bodyEl, bodyT, bodyOf(d), 0.012);
    t.to(linksEl, { opacity: 1, duration: 0.3, ease: 'power2.out' }, '>-0.05');
  }

  function show(slug: string, d: DOMStringMap) {
    if (!card || slug === current) return;
    const first = current === null;
    current = slug;
    pv?.classList.add('pv-active');
    tl?.kill();

    if (reduce || isMobile()) {
      reset();
      if (titleT) titleT.textContent = d.title || '';
      if (bodyT) bodyT.textContent = bodyOf(d);
      setLinks(d);
      gsap.set([card, linksEl], { opacity: 1, x: 0 });
      return;
    }

    tl = gsap.timeline();
    if (first) {
      reset();
      gsap.set(card, { opacity: 0, x: -40 });
      enterIn(tl);
      typeDossier(tl, d);
    } else {
      leaveOut(tl, reset);
      enterIn(tl);
      typeDossier(tl, d);
    }
  }

  function hide() {
    if (!card || current === null) return;
    current = null;
    pv?.classList.remove('pv-active');
    tl?.kill();
    tl = gsap.timeline();
    leaveOut(tl);
  }

  // Desktop: click a project to reveal it, click it again to close.
  // Mobile: click slides to the preview panel.
  rows.forEach((r) => {
    const slug = r.dataset.proj!;
    r.querySelector('.prj__trigger')?.addEventListener('click', () => {
      if (isMobile()) { show(slug, r.dataset); track?.classList.add('is-preview'); return; }
      if (slug === current) hide(); else show(slug, r.dataset);
    });
  });
  back?.addEventListener('click', () => { track?.classList.remove('is-preview'); });
</script>
